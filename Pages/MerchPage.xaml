<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Meowbah.MerchPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Meowbah"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="8">
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup>
                <VisualState x:Name="Wide">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="1200" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="ItemsWrapGridPanel.ItemWidth" Value="300" />
                        <Setter Target="ItemsWrapGridPanel.ItemHeight" Value="220" />
                    </VisualState.Setters>
                </VisualState>

                <VisualState x:Name="Normal">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="800" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="ItemsWrapGridPanel.ItemWidth" Value="300" />
                        <Setter Target="ItemsWrapGridPanel.ItemHeight" Value="180" />
                    </VisualState.Setters>
                </VisualState>

                <VisualState x:Name="Narrow">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="0" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="ItemsWrapGridPanel.ItemWidth" Value="360" />
                        <Setter Target="ItemsWrapGridPanel.ItemHeight" Value="220" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>

        <Grid RowDefinitions="Auto,*">
            <TextBlock Grid.Row="0" FontSize="28" FontWeight="SemiBold" Text="Merch" Margin="0,0,0,12" />

            <!-- GridView bound to MerchItems to display items in multiple columns -->
            <GridView Grid.Row="1" ItemsSource="{x:Bind MerchItems}" IsItemClickEnabled="False" SelectionMode="None"
                      VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
                      Padding="0" Margin="0"
                      HorizontalContentAlignment="Left"
                      ScrollViewer.VerticalScrollMode="Enabled"
                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                      ScrollViewer.HorizontalScrollMode="Disabled"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <GridView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <ItemsWrapGrid x:Name="ItemsWrapGridPanel" Orientation="Horizontal" ItemWidth="300" ItemHeight="180" HorizontalAlignment="Left" />
                    </ItemsPanelTemplate>
                </GridView.ItemsPanel>

                <GridView.ItemTemplate>
                    <DataTemplate x:DataType="local:MerchItem">
                        <Grid Padding="8" ColumnDefinitions="150, *" ColumnSpacing="12">
                            <Border Grid.Column="0" Width="150" Height="150" CornerRadius="8" Background="#FFF0F0F0" HorizontalAlignment="Left" VerticalAlignment="Top">
                                <Image Source="{x:Bind ImageSource}" Stretch="UniformToFill" />
                            </Border>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="{x:Bind Title}" FontSize="18" FontWeight="SemiBold" />
                                <TextBlock Text="{x:Bind Description}" TextWrapping="Wrap" Margin="0,6,0,0" />
                                <TextBlock Text="{x:Bind Price}" FontSize="16" FontWeight="SemiBold" Margin="0,8,0,0" />
                                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                    <Button Content="Buy" />
                                    <Button Content="Details" Margin="8,0,0,0" />
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </GridView.ItemTemplate>
            </GridView>

        </Grid>
    </Grid>
</Page>